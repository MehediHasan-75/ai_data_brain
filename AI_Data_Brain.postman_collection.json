            "body": { "mode": "raw", "raw": "{\n  \"action\": \"remove\",\n  \"friend_id\": 2\n}" },
            "url": { "raw": "{{base_url}}/auth/friends/manage/", "host": ["{{base_url}}"], "path": ["auth", "friends", "manage", ""] }
          }
        }
      ]
    },
    {
