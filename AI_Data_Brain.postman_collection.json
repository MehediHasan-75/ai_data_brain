          "name": "List Prompts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/agent/prompts/", "host": ["{{base_url}}"], "path": ["agent", "prompts", ""] }
          }
        },
        {
          "name": "Invoke Prompt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"arguments\": {\n    \"table_name\": \"Monthly Expenses\",\n    \"month\": \"March 2026\"\n  }\n}" },
            "url": { "raw": "{{base_url}}/agent/prompts/monthly_report/", "host": ["{{base_url}}"], "path": ["agent", "prompts", "monthly_report", ""] }
