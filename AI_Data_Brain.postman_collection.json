            "body": { "mode": "raw", "raw": "{\n  \"message_id\": \"msg_1\",\n  \"text\": \"Add 500 taka for lunch\",\n  \"sender\": \"user\"\n}" },
            "url": { "raw": "{{base_url}}/agent/chat/sessions/chat_1_1707232000/messages/save/", "host": ["{{base_url}}"], "path": ["agent", "chat", "sessions", "chat_1_1707232000", "messages", "save", ""] }
          }
        },
        {
          "name": "Clear Session Messages",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/agent/chat/sessions/chat_1_1707232000/messages/", "host": ["{{base_url}}"], "path": ["agent", "chat", "sessions", "chat_1_1707232000", "messages", ""] }
