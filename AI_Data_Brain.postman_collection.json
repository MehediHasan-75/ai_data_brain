          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"Add 500 taka expense for lunch today\",\n  \"session_id\": \"optional_session_id\",\n  \"llm_provider\": \"anthropic\",\n  \"llm_model\": \"claude-sonnet-4-6\"\n}" },
            "url": { "raw": "{{base_url}}/agent/query/", "host": ["{{base_url}}"], "path": ["agent", "query", ""] }
          }
        },
        {
          "name": "Query Agent (Streaming SSE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"Show me all my expenses for this month\",\n  \"session_id\": \"optional_session_id\",\n  \"llm_provider\": \"anthropic\",\n  \"llm_model\": \"claude-sonnet-4-6\"\n}" },
            "url": { "raw": "{{base_url}}/agent/streaming/", "host": ["{{base_url}}"], "path": ["agent", "streaming", ""] }
          }
        },
        {
          "name": "Agent History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/agent/history/", "host": ["{{base_url}}"], "path": ["agent", "history", ""] }
          }
        }
      ]
    },
    {
      "name": "Prompt Templates",
      "item": [
